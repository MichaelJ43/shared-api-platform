{
  "name": "shared-api-platform-lambda",
  "private": true,
  "version": "0.0.22",
  "type": "commonjs",
  "main": "dist/handler.js",
  "scripts": {
    "ensure:xdb": "node scripts/ensure-ip2region-xdb.mjs",
    "build": "npm run openapi:generate && npm run ensure:xdb && node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build:lambda": "npm run ensure:xdb && node scripts/bundle.mjs",
    "openapi:generate": "tsx src/openapi-generate.ts",
    "test": "npm run ensure:xdb && vitest run",
    "test:cov": "npm run ensure:xdb && vitest run --coverage",
    "lint:oas": "spectral lint --ruleset ../.spectral.yaml ../openapi/openapi.yaml",
    "auth:create-user": "node scripts/create-user.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.0",
    "@aws-sdk/client-dynamodb": "^3.675.0",
    "@aws-sdk/lib-dynamodb": "^3.675.0",
    "argon2": "^0.44.0",
    "ip2region.js": "^3.1.8",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0",
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.0",
    "archiver": "^7.0.1",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "yaml": "^2.6.0"
  }
}
